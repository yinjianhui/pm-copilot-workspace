# PM Copilot Workspace - Environment Configuration Example
# Copy this file to .env and fill in your values

# ============================================================================
# Application Settings
# ============================================================================
APP_NAME=PM Copilot Workspace
APP_VERSION=0.1.0
DEBUG=True

# ============================================================================
# Server Settings
# ============================================================================
HOST=0.0.0.0
PORT=8000

# ============================================================================
# Database Settings
# ============================================================================
DATABASE_URL=sqlite:///./pm_copilot.db

# ============================================================================
# Authentication Settings
# ============================================================================
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================================
# API Settings
# ============================================================================
API_V1_PREFIX=/api/v1

# ============================================================================
# CORS Settings
# ============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# AI Model API Keys
# ============================================================================

# Anthropic Claude API
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# DeepSeek API (OpenAI-compatible)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# GLM (智谱清言 / Zhipu AI) API
# Get your key at: https://open.bigmodel.cn/usercenter/apikeys
GLM_API_KEY=your-glm-api-key-here

# ============================================================================
# Vector Store Settings (Future)
# ============================================================================
CHROMA_PERSIST_DIRECTORY=./chroma_db
